rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User Permissions Collection
    // Document ID matches the user's email address
    match /user_permissions/{email} {
      // Allow read/write if the authenticated user's email matches the document ID
      allow read, write: if request.auth != null && request.auth.token.email == email;
    }
  }
}
